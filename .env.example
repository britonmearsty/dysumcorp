# Database
DATABASE_URL="postgresql://..."

# Auth - Replace with your production domain
BETTER_AUTH_SECRET="your-secret-key-min-32-chars"
BETTER_AUTH_URL="https://your-domain.com"
NEXT_PUBLIC_BETTER_AUTH_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Resend Email
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="DysumCorp <info@your-domain.com>"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Dropbox OAuth
DROPBOX_CLIENT_ID="your-dropbox-client-id"
DROPBOX_CLIENT_SECRET="your-dropbox-client-secret"

# Creem Billing - Use production key
CREEM_API_KEY="creem_prod_..."

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Analytics
NEXT_PUBLIC_FACEBOOK_PIXEL_ID="your-pixel-id"

# Sentry Error Monitoring
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
SENTRY_ORG="your-org"
SENTRY_PROJECT="dysumcorp"

# Admin Configuration
ADMIN_EMAILS="admin@your-domain.com"
ADMIN_DOMAIN="your-domain.com"

# Storage Configuration
STORAGE_ROOT_FOLDER="dysumcorp"
