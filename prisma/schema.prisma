generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["tracing"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      Boolean   @default(false)
  image              String?
  portalLogo         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  // Polar billing
  polarCustomerId        String?
  polarSubscriptionId    String?
  polarCurrentPeriodEnd  DateTime?
  // Subscription state: "free" | "pro"
  subscriptionPlan   String?   @default("free")
  // Status: "active" | "cancelled" | "past_due"
  subscriptionStatus String?   @default("active")
  status             String    @default("active") // active, deleted, suspended
  deletedAt          DateTime?
  accounts           Account[]
  portals            Portal[]
  sessions           Session[]

  notifyOnUpload          Boolean @default(true)
  notifyOnDownload        Boolean @default(true)
  notifyOnSignIn          Boolean @default(true)
  notifyOnPortalCreate    Boolean @default(true)
  notifyOnStorageWarning  Boolean @default(true)
  weeklyReports           Boolean @default(false)

  // "ask" = show checkbox in delete modal, "always" = always delete from storage, "never" = never delete from storage
  storageDeleteBehavior String @default("ask")

  // Trial portal tracking: true if user has created their free trial portal
  // REVERSIBILITY: Can be safely removed if trial feature is discontinued
  hasCreatedTrialPortal Boolean @default(false)

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
  @@map("verification")
}

model Portal {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  customDomain        String?  @unique
  whiteLabeled        Boolean  @default(false)
  isActive            Boolean  @default(true)
  userId              String
  primaryColor        String   @default("#6366f1")
  secondaryColor      String   @default("#8b5cf6")
  textColor           String   @default("#1e293b")
  backgroundColor     String   @default("#f1f5f9")
  cardBackgroundColor String   @default("#ffffff")
  gradientEnabled     Boolean  @default(true)
  logoUrl             String?
  companyWebsite      String?
  companyEmail        String?
  storageProvider     String?
  storageFolderId     String?
  storageFolderPath   String?
  useClientFolders    Boolean  @default(false)
  password            String?
  requireClientName   Boolean  @default(true)
  requireClientEmail  Boolean  @default(false)
  maxFileSize         BigInt   @default(52428800)
  allowedFileTypes    String[] @default([])
  welcomeMessage      String?
  welcomeToastMessage String?
  welcomeToastDelay   Int      @default(1000)
  welcomeToastDuration Int     @default(3000)
  submitButtonText    String   @default("Initialize Transfer")
  successMessage      String   @default("Transmission Verified")
  textboxSectionEnabled Boolean @default(false)
  textboxSectionTitle  String?
  textboxSectionPlaceholder String?
  textboxSectionRequired Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  files               File[]
  uploadSessions      UploadSession[]
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("portal")
}

model UploadSession {
  id            String   @id @default(cuid())
  portalId      String
  uploaderName  String?
  uploaderEmail String?
  uploaderNotes String?
  uploadedAt    DateTime @default(now())
  fileCount     Int      @default(0)
  totalSize     BigInt   @default(0)
  portal        Portal   @relation(fields: [portalId], references: [id], onDelete: Cascade)
  files         File[]

  @@index([portalId])
  @@index([uploaderEmail])
  @@index([uploadedAt])
  @@map("upload_session")
}

model File {
  id              String         @id @default(cuid())
  name            String
  size            BigInt
  mimeType        String
  storageUrl      String
  storageFileId   String?
  portalId        String
  uploadSessionId String?
  uploadedAt      DateTime       @default(now())
  expiresAt       DateTime?
  passwordHash    String?
  downloads       Int            @default(0)
  uploaderName    String?
  uploaderEmail   String?
  portal          Portal         @relation(fields: [portalId], references: [id], onDelete: Cascade)
  uploadSession   UploadSession? @relation(fields: [uploadSessionId], references: [id], onDelete: SetNull)

  @@index([portalId])
  @@index([uploaderEmail])
  @@index([uploadSessionId])
  @@map("file")
}

model UsageTracking {
  id             String   @id @default(cuid())
  userId         String
  month          String
  storageUsed    BigInt   @default(0)
  portalsCreated Int      @default(0)
  filesUploaded  Int      @default(0)
  bandwidth      BigInt   @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
  @@map("usage_tracking")
}

model R2StagingUpload {
  id             String   @id @default(cuid())
  stagingKey     String   @unique
  portalId       String
  fileSize       BigInt

  // State Machine: PENDING → UPLOADING → UPLOADED → ROUTING → DELIVERED | FAILED
  status         String   @default("PENDING")

  // Delivery Tracking
  targetProvider String?  // "google" | "dropbox"
  targetPath     String?  // Full path in user's cloud
  targetFileId   String?  // Provider's returned file ID

  // Retry & Error Tracking
  attempts       Int      @default(0)
  lastError      String?

  // Idempotency
  r2Etag         String?
  r2Hash         String?

  // Metadata
  uploaderName   String?
  uploaderEmail  String?
  fileId         String?  // Created File record after delivery

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, portalId])
  @@index([portalId, status])
  @@map("r2_staging_upload")
}
