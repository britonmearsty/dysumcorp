generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
  previewFeatures = ["tracing"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      Boolean   @default(false)
  image              String?
  portalLogo         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  creemCustomerId    String?
  hadTrial           Boolean?  @default(false)
  trialStartedAt     DateTime?
  subscriptionPlan   String?   @default("trial")
  subscriptionStatus String?   @default("trialing")
  accounts           Account[]
  portals            Portal[]
  sessions           Session[]

  notifyOnUpload     Boolean   @default(true)
  notifyOnDownload  Boolean   @default(true)
  notifyOnSignIn     Boolean   @default(true)
  notifyOnPortalCreate Boolean @default(true)
  notifyOnStorageWarning Boolean @default(true)
  weeklyReports      Boolean   @default(false)

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
  @@map("verification")
}

model Creem_subscription {
  id                  String    @id
  productId           String
  referenceId         String
  creemCustomerId     String?
  creemSubscriptionId String?
  creemOrderId        String?
  status              String?   @default("pending")
  periodStart         DateTime?
  periodEnd           DateTime?
  cancelAtPeriodEnd   Boolean?  @default(false)

  @@map("creem_subscription")
}

model Portal {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  customDomain        String?  @unique
  whiteLabeled        Boolean  @default(false)
  isActive            Boolean  @default(true)
  userId              String
  primaryColor        String   @default("#6366f1")
  secondaryColor      String   @default("#8b5cf6")
  textColor           String   @default("#1e293b")
  backgroundColor     String   @default("#f1f5f9")
  cardBackgroundColor String   @default("#ffffff")
  gradientEnabled     Boolean  @default(true)
  logoUrl             String?
  companyWebsite      String?
  companyEmail        String?
  storageProvider     String?
  storageFolderId     String?
  storageFolderPath   String?
  useClientFolders    Boolean  @default(false)
  password            String?
  requireClientName   Boolean  @default(true)
  requireClientEmail  Boolean  @default(false)
  maxFileSize         BigInt   @default(52428800)
  allowedFileTypes    String[] @default([])
  welcomeMessage      String?
  welcomeToastMessage String?
  welcomeToastDelay   Int      @default(1000)
  welcomeToastDuration Int     @default(3000)
  submitButtonText    String   @default("Initialize Transfer")
  successMessage      String   @default("Transmission Verified")
  textboxSectionEnabled Boolean @default(false)
  textboxSectionTitle  String?
  textboxSectionRequired Boolean @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  files               File[]
  uploadSessions      UploadSession[]
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("portal")
}

model UploadSession {
  id            String   @id @default(cuid())
  portalId      String
  uploaderName  String?
  uploaderEmail String?
  uploaderNotes String?
  uploadedAt    DateTime @default(now())
  fileCount     Int      @default(0)
  totalSize     BigInt   @default(0)
  portal        Portal   @relation(fields: [portalId], references: [id], onDelete: Cascade)
  files         File[]

  @@index([portalId])
  @@index([uploaderEmail])
  @@index([uploadedAt])
  @@map("upload_session")
}

model File {
  id              String         @id @default(cuid())
  name            String
  size            BigInt
  mimeType        String
  storageUrl      String
  storageFileId   String?
  portalId        String
  uploadSessionId String?
  uploadedAt      DateTime       @default(now())
  expiresAt       DateTime?
  passwordHash    String?
  downloads       Int            @default(0)
  uploaderName    String?
  uploaderEmail   String?
  portal          Portal         @relation(fields: [portalId], references: [id], onDelete: Cascade)
  uploadSession   UploadSession? @relation(fields: [uploadSessionId], references: [id], onDelete: SetNull)

  @@index([portalId])
  @@index([uploaderEmail])
  @@index([uploadSessionId])
  @@map("file")
}

model UsageTracking {
  id             String   @id @default(cuid())
  userId         String
  month          String
  storageUsed    BigInt   @default(0)
  portalsCreated Int      @default(0)
  filesUploaded  Int      @default(0)
  bandwidth      BigInt   @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
  @@map("usage_tracking")
}

model R2StagingUpload {
  id            String   @id @default(cuid())
  stagingKey    String   @unique
  portalId      String
  fileSize      BigInt
  status        String   @default("pending") // pending | completed | failed
  uploaderName  String?
  uploaderEmail String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@map("r2_staging_upload")
}


