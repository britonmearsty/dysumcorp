generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      Boolean   @default(false)
  image              String?
  portalLogo         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  creemCustomerId    String?
  hadTrial           Boolean?  @default(false)
  subscriptionPlan   String?   @default("free")
  subscriptionStatus String?   @default("active")
  accounts           Account[]
  portals            Portal[]
  sessions           Session[]

  notifyOnUpload     Boolean   @default(true)
  notifyOnDownload  Boolean   @default(true)
  notifyOnSignIn     Boolean   @default(true)
  notifyOnPortalCreate Boolean @default(true)
  notifyOnStorageWarning Boolean @default(true)
  weeklyReports      Boolean   @default(false)

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
  @@map("verification")
}

model Creem_subscription {
  id                  String    @id
  productId           String
  referenceId         String
  creemCustomerId     String?
  creemSubscriptionId String?
  creemOrderId        String?
  status              String?   @default("pending")
  periodStart         DateTime?
  periodEnd           DateTime?
  cancelAtPeriodEnd   Boolean?  @default(false)

  @@map("creem_subscription")
}

model Portal {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  customDomain        String?  @unique
  whiteLabeled        Boolean  @default(false)
  isActive            Boolean  @default(true)
  userId              String
  primaryColor        String   @default("#3b82f6")
  textColor           String   @default("#0f172a")
  backgroundColor     String   @default("#ffffff")
  cardBackgroundColor String   @default("#ffffff")
  logoUrl             String?
  storageProvider     String?
  storageFolderId     String?
  storageFolderPath   String?
  useClientFolders    Boolean  @default(false)
  password            String?
  requireClientName   Boolean  @default(true)
  requireClientEmail  Boolean  @default(false)
  maxFileSize         BigInt   @default(52428800)
  allowedFileTypes    String[] @default([])
  welcomeMessage      String?
  submitButtonText    String   @default("Initialize Transfer")
  successMessage      String   @default("Transmission Verified")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  files               File[]
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("portal")
}

model File {
  id            String    @id @default(cuid())
  name          String
  size          BigInt
  mimeType      String
  storageUrl    String
  storageFileId String?
  portalId      String
  uploadedAt    DateTime  @default(now())
  expiresAt     DateTime?
  passwordHash  String?
  downloads     Int       @default(0)
  uploaderName  String?
  uploaderEmail String?
  portal        Portal    @relation(fields: [portalId], references: [id], onDelete: Cascade)

  @@index([portalId])
  @@index([uploaderEmail])
  @@map("file")
}

model UsageTracking {
  id             String   @id @default(cuid())
  userId         String
  month          String
  storageUsed    BigInt   @default(0)
  portalsCreated Int      @default(0)
  filesUploaded  Int      @default(0)
  bandwidth      BigInt   @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([userId, month])
  @@index([userId])
  @@map("usage_tracking")
}
